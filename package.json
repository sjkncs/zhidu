{
  "name": "zhidu",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered college application guidance and growth management platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@zhidu/web",
    "dev:desktop": "turbo run dev --filter=@zhidu/desktop",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@zhidu/web",
    "build:desktop": "turbo run build --filter=@zhidu/desktop",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
