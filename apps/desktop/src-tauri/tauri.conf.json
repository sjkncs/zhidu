{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Zhidu",
  "version": "0.1.0",
  "identifier": "com.zhidu.app",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "cd ../../web && npx next dev --port 3001",
    "beforeBuildCommand": "cd ../../web && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Zhidu",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
