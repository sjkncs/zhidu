# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek LLM
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱) LLM
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4-flash

# Embedding (智谱官方 API key，从 open.bigmodel.cn 获取)
ZHIPU_EMBEDDING_KEY=your-zhipu-embedding-key

# ML 推理服务地址 (可选，默认 http://localhost:5100)
# ML_SERVICE_URL=http://localhost:5100

# ML 服务 API Key (与 serve.py 中的 ML_API_KEY 保持一致)
ML_API_KEY=your-ml-api-key

# Web Search (网络搜索 — web_search 工具)
# 主引擎: DuckDuckGo HTML (免费，无需配置)
# 备选引擎: Bing Web Search API (DDG 限流时自动回退)
# 免费额度: 1000 次/月，申请: https://portal.azure.com → 创建 "Bing Search v7" 资源 (F1 Free)
# BING_SEARCH_API_KEY=your-bing-search-api-key
